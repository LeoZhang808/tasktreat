###############################################################################
# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.
#
# Do NOT put real passwords in this file if it might be committed. Prefer
# exporting db_password as an environment variable:
#
#   export TF_VAR_db_password='replace-with-a-strong-password'
###############################################################################

project_name = "tasktreat"
environment  = "dev"
aws_region   = "us-west-2"
owner        = "leo-zhang"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-west-2a", "us-west-2b"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.101.0/24", "10.0.102.0/24"]
single_nat_gateway   = true

eks_cluster_name        = "tasktreat-dev-eks"
eks_cluster_version     = "1.30"
eks_node_instance_types = ["t3.medium"]
eks_desired_size        = 2
eks_min_size            = 2
eks_max_size            = 4
eks_node_disk_size_gb   = 40

# Restrict the public EKS API endpoint. Use ["<your-ip>/32"] for tighter
# security; "0.0.0.0/0" is open to the world.
eks_public_access_cidrs = ["0.0.0.0/0"]

db_name                    = "tasktreat"
db_username                = "tasktreat"
# db_password should be supplied via TF_VAR_db_password or an untracked
# tfvars file. Do NOT commit a real value here.
# db_password              = "replace-with-secure-password"
db_instance_class          = "db.t3.micro"
db_engine_version          = "16.13"
db_allocated_storage_gb    = 20
db_backup_retention_period = 1
db_multi_az                = false
db_skip_final_snapshot     = true
db_deletion_protection     = false

# --- Public DNS / TLS (Step 5) ------------------------------------------------
# Apex domain registered through GitHub Student Pack at Name.com. After the
# first apply, copy the Route 53 nameservers into Name.com under
# "Manage Nameservers" so DNS for the domain (and ACM DNS validation)
# resolves through Route 53.
domain_name   = "tasktreat.dev"
app_subdomain = "app"

# --- Step 6: GitHub Actions OIDC (optional) ------------------------------------
# When set to "owner/repo", Terraform creates:
#   * IAM role <project>-dev-github-actions-deploy-role (ECR + EKS describe)
#   * EKS access entry + namespace-scoped admin policy for CI namespaces
# Leave empty to skip (useful before the GitHub repo exists).
#
# If your AWS account already has an IAM OIDC provider for
# token.actions.githubusercontent.com, set github_oidc_provider_arn to that ARN
# and Terraform will not try to create a duplicate provider.
#
# github_repository = "your-github-username/tasktreat"
# github_oidc_provider_arn = ""
