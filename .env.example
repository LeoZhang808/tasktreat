# Shared by all three backend services.
# Copy this file to a per-service .env (or set in the environment) when running locally.
# Each service owns its own Postgres schema (task / wishlist / reward) inside the same DB,
# so set the per-service DATABASE_URL accordingly. Example values:
#   task-service:     postgresql://tasktreat:tasktreat@localhost:5432/tasktreat?schema=task
#   wishlist-service: postgresql://tasktreat:tasktreat@localhost:5432/tasktreat?schema=wishlist
#   reward-service:   postgresql://tasktreat:tasktreat@localhost:5432/tasktreat?schema=reward
DATABASE_URL=postgresql://tasktreat:tasktreat@localhost:5432/tasktreat?schema=public

# Service ports
TASK_SERVICE_PORT=4001
WISHLIST_SERVICE_PORT=4002
REWARD_SERVICE_PORT=4003

# Reward service inter-service URLs (local dev)
TASK_SERVICE_URL=http://localhost:4001
WISHLIST_SERVICE_URL=http://localhost:4002

# Reward tuning
REWARD_VALUE_PER_TASK=5

NODE_ENV=development
